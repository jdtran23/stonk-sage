# --- SEC EDGAR fair-access identity ---
# Required by SEC: a contact string of the form "Name email@example.com".
# edgartools reads this from EDGAR_IDENTITY at import time.
#
# IMPORTANT: use a REAL, conventional email. SEC fair-access enforcement returns
# 403 Forbidden for placeholder / "noreply" User-Agents — in particular
# *@users.noreply.github.com (a git default) is blocked. If you see
# `EdgarAccessDenied: SEC EDGAR returned 403`, fix this value first.
EDGAR_IDENTITY=Your Name your.email@example.com

# --- That's it. ---
# stonk-sage v0 (Plan B) dispatches LLM agents via Copilot CLI's `task` tool,
# which runs on the GitHub Copilot subscription. No third-party LLM API keys
# (Anthropic / OpenAI / Google) are required.
